{
  "name": "ai-agent-ecom",
  "version": "2.0.0",
  "description": "Local-first plugin-based AI agent for eCommerce development",
  "activePlugins": [
    "ecommerce-storefront"
  ],
  "settings": {
    "skillsDir": "./plugins",
    "contextOutputDir": "./.cursor/rules",
    "maxSkillsPerContext": 15,
    "includeReference": true,
    "verboseLoader": false,
    "cache": {
      "enabled": true,
      "dir": ".agent-cache",
      "ttlSeconds": 3600
    },
    "debug": false,
    "watchMode": false
  },
  "models": {
    "preferred": "claude",
    "compatible": ["claude", "gemini", "gpt-4", "mistral", "llama"]
  },
  "editor": {
    "cursor": {
      "rulesDir": ".cursor/rules",
      "autoSync": true
    },
    "vscode": {
      "instructionsDir": ".vscode/instructions",
      "autoSync": true
    },
    "antigravity": {
      "rulesDir": ".antigravity/rules",
      "autoSync": true
    }
  },
  "reasoning": {
    "enabled": true,
    "loop": ["THINK", "PLAN", "EXECUTE", "REVIEW", "IMPROVE"],
    "selfCritiqueEnabled": true,
    "antiPatternCheckEnabled": true
  }
}
